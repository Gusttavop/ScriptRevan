  function setupEventListeners() {
    const elements = window.ItemSelectorState.elements;
    if (!elements) return;
    const { searchInput, clearButton, dropdown, overlay, aguardarCheckbox, finalizarCheckbox, holderCheckbox, relationshipSelect, speakerInput, observationsTextarea, buttonContainer, sidebar, editButton, closeBtn, saveEditButton, cancelEditButton } = elements;

    const openSidebarBtn = document.getElementById("openSidebarBtn");
    if (openSidebarBtn) {
      openSidebarBtn.addEventListener("click", () => {
        sidebar.classList.add("open");
        overlay.style.display = "block";
        updateAvailableTags();
        filterAndDisplayItems();
      });
    }

    overlay.addEventListener("click", () => {
      sidebar.classList.remove("open");
      overlay.style.display = "none";
      closeEditModal();
    });

    searchInput.addEventListener("input", () => {
      filterAndDisplayItems();
      dropdown.style.display = "block";
      searchInput.style.borderRadius = "10px 10px 0 0";
    });

    searchInput.addEventListener("focus", () => {
      dropdown.style.display = "block";
      searchInput.style.borderRadius = "10px 10px 0 0";
    });

    clearButton.addEventListener("click", e => {
      e.stopPropagation();
      searchInput.value = "";
      window.ItemSelectorState.selectedItem = null;
      window.ItemSelectorState.mensagemFinal = "";
      clearButton.style.display = "none";
      elements.specificationSection.style.display = "none";
      buttonContainer.style.display = "none";
      elements.previewSection.style.display = "none";
      closeEditModal();
      resetElementsToDefault();
      filterAndDisplayItems();
      updateButtonState();
    });

    document.addEventListener("click", e => {
      if (!searchInput.contains(e.target) && !dropdown.contains(e.target)) {
        dropdown.style.display = "none";
        searchInput.style.borderRadius = "10px";
      }
    });

    // Lógica para as checkboxes se desmarcarem mutuamente
    aguardarCheckbox.querySelector("input").addEventListener("change", e => {
        if (e.target.checked) finalizarCheckbox.querySelector("input").checked = false;
        updatePreview();
    });

    finalizarCheckbox.querySelector("input").addEventListener("change", e => {
        if (e.target.checked) aguardarCheckbox.querySelector("input").checked = false;
        updatePreview();
    });

    holderCheckbox.querySelector("input").addEventListener("change", e => {
      speakerInput.style.display = e.target.checked ? "none" : "block";
      relationshipSelect.style.display = e.target.checked ? "none" : "block";
      updatePreview();
    });
    speakerInput.addEventListener("input", updatePreview);
    relationshipSelect.querySelector("select").addEventListener("change", updatePreview);
    observationsTextarea.addEventListener("input", updatePreview);

    editButton.addEventListener("click", e => {
      e.preventDefault();
      openEditModal();
    });

    closeBtn.addEventListener("click", closeEditModal);
    saveEditButton.addEventListener("click", saveEdit);
    cancelEditButton.addEventListener("click", closeEditModal);

    holderCheckbox.querySelector("input").checked = true;
    speakerInput.style.display = "none";
    relationshipSelect.style.display = "none";

    const sendButton = buttonContainer.querySelector(".send-button");
    if (sendButton) {
      sendButton.addEventListener("click", e => {
        e.preventDefault();
        try {
          window.tagExt();
          executarAutomacao().catch(err => console.error("exec automacao:", err));
        } catch (err) {
          console.error("Erro ao chamar tagExt/exec:", err);
        }
      });
    }
    updateButtonState();
  }

  function setupDraggableButton() {
    const button = document.getElementById("openSidebarBtn");
    if (!button) return;
    let isDragging = false;
    let startX, startY, xOffset = 0, yOffset = 0;

    function onPointerDown(clientX, clientY) {
      isDragging = true;
      startX = clientX - xOffset;
      startY = clientY - yOffset;
      button.style.transition = "none";
    }
    function onPointerMove(clientX, clientY) {
      if (!isDragging) return;
      xOffset = clientX - startX;
      yOffset = clientY - startY;
      button.style.transform = `translate3d(${xOffset}px, ${yOffset}px, 0)`;
    }
    function onPointerUp() {
      isDragging = false;
      button.style.transition = "";
    }

    button.addEventListener("mousedown", e => onPointerDown(e.clientX, e.clientY));
    document.addEventListener("mousemove", e => onPointerMove(e.clientX, e.clientY));
    document.addEventListener("mouseup", onPointerUp);
    button.addEventListener("touchstart", e => onPointerDown(e.touches[0].clientX, e.touches[0].clientY), {passive: true});
    document.addEventListener("touchmove", e => { if(isDragging) onPointerMove(e.touches[0].clientX, e.touches[0].clientY) }, {passive: true});
    document.addEventListener("touchend", onPointerUp);
  }

  function init() {
    addStyles();
    window.ItemSelectorState.elements = createElements();
    if (!window.ItemSelectorState.elements) return;
    document.body.appendChild(window.ItemSelectorState.elements.sidebar);
    setupEventListeners();
    setupDraggableButton();
    loadAndFilterData();
    window.ItemSelector.onItemSelected(item => console.log("Novo item:", item));
  }

  async function loadAndFilterData() {
    try {
      const response = await fetch("https://raw.githubusercontent.com/Gusttavop/RevanAntigo/refs/heads/main/Problemas.json");
      window.ItemSelectorState.jsonData = await response.json();
      filterAndDisplayItems();
    } catch (error) { console.error("Erro dados:", error); }
  }

  function normalizeString(str = "") {
    return String(str).toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/\s+/g, "");
  }

  function filterAndDisplayItems() {
    if (!window.ItemSelectorState.elements?.searchInput) return;
    const searchTerm = normalizeString(window.ItemSelectorState.elements.searchInput.value);
    const filteredItems = (window.ItemSelectorState.jsonData || []).filter(item => {
      const matchesSearch = normalizeString(item.titulo).includes(searchTerm);
      const matchesTag = item.infra === "Geral" || window.ItemSelectorState.availableTags.has(mapInfraToTag(item.infra));
      return matchesSearch && matchesTag;
    });
    displayItems(filteredItems);
  }

  function mapInfraToTag(infra) {
    const mapping = { Fibra: "Fibra", IPTV: "IPTV", Telefonia: "Telefonia", FWA: "FWA", Geral: "Geral" };
    return mapping[infra] || "Geral";
  }

  function displayItems(items) {
    if (!window.ItemSelectorState.elements.dropdown) return;
    const dd = window.ItemSelectorState.elements.dropdown;
    dd.innerHTML = "";
    items.forEach(item => {
      const li = document.createElement("li");
      li.textContent = item.titulo;
      li.addEventListener("click", () => {
        resetElementsToDefault();
        window.ItemSelectorState.selectedItem = item;
        window.ItemSelectorState.mensagemFinal = "";
        updateUIOnSelection(item);
        if (typeof window.ItemSelectorState.onItemSelectedCallback === "function") window.ItemSelectorState.onItemSelectedCallback(item);
      });
      dd.appendChild(li);
    });
  }

  function updateUIOnSelection(item) {
    const elements = window.ItemSelectorState.elements;
    elements.searchInput.value = item.titulo || "";
    elements.clearButton.style.display = "flex";
    elements.dropdown.style.display = "none";
    elements.searchInput.style.borderRadius = "10px";
    elements.specificationSection.style.display = "block";

    // Mostra as duas caixas
    elements.aguardarCheckbox.style.display = "block";
    elements.finalizarCheckbox.style.display = "block";
    
    const cbAguardar = elements.aguardarCheckbox.querySelector("input");
    const cbFinalizar = elements.finalizarCheckbox.querySelector("input");
    
    if (cbAguardar && cbFinalizar) {
        const tituloLower = item.titulo ? item.titulo.toLowerCase() : "";
        const isAguardarPadrao = item.aguardar || 
                                 tituloLower.includes("comodo") || 
                                 tituloLower.includes("cômodo") || 
                                 tituloLower.includes("estruturada");
        
        // Se for de aguardar, marca "Aguardar" e desmarca "Finalizar".
        // Caso contrário, marca "Finalizar" e desmarca "Aguardar".
        cbAguardar.checked = !!isAguardarPadrao;
        cbFinalizar.checked = !isAguardarPadrao;
    }

    elements.observationsTextarea.style.display = "block";
    elements.buttonContainer.style.display = "flex";
    elements.previewSection.style.display = "block";
    updateButtonState();
    updatePreview();
    try { window.tagExt(); } catch (err) { window.tagResult = false; }
  }

  function updatePreview() {
    if (!window.ItemSelectorState.selectedItem) return;
    const s = window.ItemSelectorState.selectedItem;
    window.ItemSelectorState.elements.internalLabelPreview.innerHTML = `<h4>Etiqueta Interna:</h4><p>${s.etiqueta || ""}</p>`;
    window.ItemSelectorState.elements.externalLabelPreview.innerHTML = `<h4>Etiqueta Externa:</h4><p>${s.etiqueta_externo || "N/A"}</p>`;
    window.ItemSelectorState.elements.finalMessagePreview.innerHTML = `<h4>Mensagem Final:</h4><p>${window.construirMensagemFinal()}</p>`;
  }

  function updateButtonState() {
    const sendButton = window.ItemSelectorState.elements.buttonContainer.querySelector(".send-button");
    const editButton = window.ItemSelectorState.elements.buttonContainer.querySelector(".edit-button");
    const isEnabled = !!window.ItemSelectorState.selectedItem;
    if (sendButton) sendButton.disabled = !isEnabled;
    if (editButton) editButton.disabled = !isEnabled;
  }

  function updateAvailableTags() {
    window.ItemSelectorState.availableTags.clear();
    document.querySelectorAll("div.tags > div.tag > nz-tag > span").forEach(tag => {
      if (tag && tag.textContent) window.ItemSelectorState.availableTags.add(tag.textContent.trim());
    });
  }

  function resetElementsToDefault() {
    const elements = window.ItemSelectorState.elements;
    if (!elements) return;
    try {
      elements.aguardarCheckbox.querySelector("input").checked = false;
      elements.finalizarCheckbox.querySelector("input").checked = false;
      elements.holderCheckbox.querySelector("input").checked = true;
    } catch (e) {}
    elements.speakerInput.value = "";
    elements.observationsTextarea.value = "";
    elements.editMessageTextarea.value = "";
    const sel = elements.relationshipSelect.querySelector("select");
    if (sel) sel.selectedIndex = 0;
    window.ItemSelectorState.mensagemFinal = "";
    closeEditModal();
  }

  function closeSidebar() {
    const sidebar = document.getElementById("sidebar");
    const overlay = document.getElementById("sidebar-overlay");
    if (sidebar) sidebar.classList.remove("open");
    if (overlay) overlay.style.display = "none";
  }

  init();

  async function fecharModalSeTravado() {
      console.log("Tentando destravar modal (clicar em Cancelar)...");
      const xpathsCancelar = ["//button[contains(., 'Cancelar')]", "//button[@aria-label='Close']", "//span[contains(@class, 'ant-modal-close-x')]"];
      for (const xpath of xpathsCancelar) {
          const btn = document.evaluate(xpath, document, null, XPathResult.FIRST_ORDERED_NODE_TYPE, null).singleNodeValue;
          if (btn && btn.offsetParent !== null) {
              btn.click();
              console.log("Modal destravado via Cancelar/Fechar.");
              await new Promise(r => setTimeout(r, 500));
              return true;
          }
      }
      return false;
  }

  async function confirmarFinalizacao() {
      try {
          const xpathConfirmar = "//button[span[contains(text(), 'Sim, finalizar')]]";
          await esperarEClicar(xpathConfirmar, 100, 8000); 
          console.log("Confirmação de finalização efetuada.");
      } catch (error) { }
  }
  
  async function confirmarAguardar() {
      try {
          const xpathConfirmar = "//button[span[contains(translate(text(), 'ABCDEFGHIJKLMNOPQRSTUVWXYZ', 'abcdefghijklmnopqrstuvwxyz'), 'sim')]] | //button[span[contains(translate(text(), 'ABCDEFGHIJKLMNOPQRSTUVWXYZ', 'abcdefghijklmnopqrstuvwxyz'), 'aguardar')]]";
          await esperarEClicar(xpathConfirmar, 100, 4000);
          console.log("Confirmação de aguardar efetuada.");
      } catch (error) { 
          console.log("Não precisou de confirmação ou precisa de preenchimento manual de motivo.");
      }
  }

  async function executarAutomacao() {
    closeSidebar();
    window.tagResult = false;
    if (document.getElementById("upload")) document.getElementById("toggle_upload")?.click();

    const msgF = window.construirMensagemFinal();
    const textArea = document.querySelector(".text-area");
    if (textArea) {
      textArea.value = msgF;
      textArea.dispatchEvent(new Event("input", { bubbles: true }));
    }

    // Apenas clica em enviar mensagem, para ela ir para a timeline do chamado
    document.getElementById("send_button")?.click();

    // Verificação de etiqueta mais robusta e case-insensitive
    const desiredTag = window.ItemSelectorState.selectedItem?.etiqueta || "";
    const isExterno = window.ItemSelectorState.selectedItem?.externo; // Variável que checa se é externo
    const allTags = Array.from(document.querySelectorAll('nz-tag, .ant-tag, .chip-label, span.tag-text, .tag'));
    const tagExists = allTags.some(tag => tag.textContent.trim().toLowerCase() === desiredTag.toLowerCase());

    if (!tagExists && desiredTag) {
      console.log("Adicionando etiqueta...");
      try {
        await adicionarEtiqueta();
      } catch (err) {
        console.error("Falha ao adicionar etiqueta, tentando destravar:", err);
        await fecharModalSeTravado();
        window.tagResult = false;
      }
    } else {
      console.log("Etiqueta já existe, pulando.");
      window.tagResult = true;
    }

    // --- LOOP DE SEGURANÇA: ESPERA A ETIQUETA ---
    if (desiredTag && !isExterno) {
        // Se for INTERNO (fechamento direto), faz o loop rigoroso para não dar erro
        let tagConfirmada = false;
        for (let i = 0; i < 10; i++) {
            const currentTags = Array.from(document.querySelectorAll('nz-tag, .ant-tag, .chip-label, span.tag-text, .tag'));
            if (currentTags.some(t => t.textContent.trim().toLowerCase() === desiredTag.toLowerCase())) {
                tagConfirmada = true;
                await new Promise(r => setTimeout(r, 300)); 
                break;
            }
            await new Promise(r => setTimeout(r, 150)); 
        }
        if (!tagConfirmada) console.warn("Aviso: Etiqueta pode não ter sido confirmada antes da finalização.");
    } else if (desiredTag && isExterno) {
        // Se for EXTERNO, espera apenas uma fração de segundo
        await new Promise(r => setTimeout(r, 150));
    }
    // -------------------------------------------------------------------------

    const querAguardar = document.getElementById("aguardarCheckbox")?.checked;
    const querFinalizar = document.getElementById("finalizarCheckbox")?.checked;

    if (querAguardar) {
      // Se optou por AGUARDAR
      if (isExterno) {
        await finalizarExterno(true); // Envia para externo com switch de aguardar
        await confirmarFinalizacao();
      } else {
        await colocarEmAguardar();
        await confirmarAguardar();
      }
    } else if (querFinalizar) {
      // Se optou por FINALIZAR
      if (isExterno) {
        await finalizarExterno(false); // Envia para externo sem switch de aguardar
        await confirmarFinalizacao();
      } else {
        await finalizarInterno();
        await confirmarFinalizacao();
      }
    } else {
      // Se NENHUM dos dois estiver marcado
      console.log("Nenhuma ação de encerramento marcada. Apenas etiqueta e mensagem inseridas.");
    }
    
    // Reseta a seleção e os campos para o próximo chamado
    window.ItemSelectorState.elements.clearButton.click();
  }

  async function adicionarEtiqueta() {
    try {
      const tagElement = await esperarElemento("//nz-tag[contains(@class, 'editable-tag')]", 100, 5000);
      tagElement.click();

      const etiquetaInterna = window.ItemSelectorState.selectedItem.etiqueta;
      const tagInput = await esperarElemento("//*[@id='tags']/div/div/ul/li/input", 50, 5000);

      const labelsSelecionadas = Array.from(document.querySelectorAll('.ant-select-selection__choice__content, .ant-select-selection__choice'));
      if (labelsSelecionadas.some(el => el.textContent.includes(etiquetaInterna))) {
          console.log("Etiqueta já detectada dentro do modal (preventivo). Fechando.");
          await fecharModalSeTravado();
          window.tagResult = true;
          return;
      }

      tagInput.click();
      tagInput.value = etiquetaInterna;
      tagInput.dispatchEvent(new Event("input", { bubbles: true }));

      await esperarEClicar(
        `//li[contains(@class, 'ant-select-dropdown-menu-item') and contains(normalize-space(.), '${etiquetaInterna}')]`,
        100, 5000 
      );

      await esperarElemento(
        `//li[contains(@class, 'ant-select-selection__choice')]//div[contains(text(), '${etiquetaInterna}')]`,
        100, 3000
      );

      const concluirButton = document.querySelector('[data-testid="btn-Concluir"]');
      if (!concluirButton || concluirButton.disabled) {
         throw new Error("Botão concluir indisponível");
      }
      concluirButton.click();
      
      await new Promise(r => setTimeout(r, 500));
      
      window.tagResult = true;

    } catch (error) {
      console.warn("Erro no fluxo de etiqueta. Tentando destravar...", error);
      const destravou = await fecharModalSeTravado();
      if (destravou) {
          window.tagResult = true; 
          return;
      }
      window.tagResult = false;
      throw error;
    }
  }

  async function finalizarExterno(querAguardar) {
    const etiquetaExterno = window.ItemSelectorState.selectedItem.etiqueta_externo || "";
    document.getElementById("forward")?.click();
    await new Promise(resolve => setTimeout(resolve, 150)); 

    if (querAguardar) {
      try { await clicarComTentativas('//lib-input-switch//button[@class="ant-switch"]', '//lib-input-switch//button[@class="ant-switch ant-switch-checked"]'); } catch (e) {}
    }

    await clicarComTentativas("//nz-select[@id='sector']//input", "//ul[contains(@class, 'ant-select-dropdown-menu')]");
    await esperarElemento("//ul[contains(@class, 'ant-select-dropdown-menu') and not(contains(@style, 'display: none'))]", 100, 20000);
    await esperarEClicar("//li[contains(@class, 'ant-select-dropdown-menu-item') and contains(translate(normalize-space(.), 'ABCDEFGHIJKLMNOPQRSTUVWXYZ', 'abcdefghijklmnopqrstuvwxyz'), 'suporte externo')]", 100, 20000);
    await new Promise(resolve => setTimeout(resolve, 100)); 

    await clicarComTentativas("//nz-select[@id='problem']//input", "//ul[contains(@class, 'ant-select-dropdown-menu')]");
    const problemInput = document.evaluate("//nz-select[@id='problem']//input", document, null, XPathResult.FIRST_ORDERED_NODE_TYPE, null).singleNodeValue;
    if (problemInput) { problemInput.value = etiquetaExterno; problemInput.dispatchEvent(new Event("input", { bubbles: true })); }
    await esperarEClicar(`//li[contains(@class, 'ant-select-dropdown-menu-item') and contains(translate(normalize-space(.), 'ABCDEFGHIJKLMNOPQRSTUVWXYZ', 'abcdefghijklmnopqrstuvwxyz'), '${etiquetaExterno.toLowerCase()}')]`, 100, 20000);
    await esperarElemento(`//li[contains(@class, 'ant-select-selection__choice')]//div[contains(translate(text(), 'ABCDEFGHIJKLMNOPQRSTUVWXYZ', 'abcdefghijklmnopqrstuvwxyz'), '${etiquetaExterno.toLowerCase()}')]`, 100, 20000);

    const servicoExterno = window.ItemSelectorState.selectedItem.servico || "";
    await esperarElementoHabilitado("//nz-select[@id='service']", 300, 20000);
    await clicarComTentativas("//nz-select[@id='problem']//input", "//ul[contains(@class, 'ant-select-dropdown-menu')]");
    await new Promise(resolve => setTimeout(resolve, 100));
    await clicarComTentativas("//nz-select[@id='service']//input", "//ul[contains(@class, 'ant-select-dropdown-menu')]");
    const serviceInput = document.evaluate("//nz-select[@id='service']//input", document, null, XPathResult.FIRST_ORDERED_NODE_TYPE, null).singleNodeValue;
    if (serviceInput) { serviceInput.value = servicoExterno; serviceInput.dispatchEvent(new Event("input", { bubbles: true })); }
    await esperarEClicar(`//li[contains(@class, 'ant-select-dropdown-menu-item') and contains(translate(normalize-space(.), 'ABCDEFGHIJKLMNOPQRSTUVWXYZ', 'abcdefghijklmnopqrstuvwxyz'), '${servicoExterno.toLowerCase()}')]`, 100, 10000);
    await esperarElemento(`//div[contains(@class, 'ant-select-selection-selected-value') and contains(translate(text(), 'ABCDEFGHIJKLMNOPQRSTUVWXYZ', 'abcdefghijklmnopqrstuvwxyz'), '${servicoExterno.toLowerCase()}')]`, 100, 10000);

    document.querySelector('[data-testid="btn-Continuar"]')?.click();
  }

  async function colocarEmAguardar() {
    await new Promise(resolve => setTimeout(resolve, 350));
    document.querySelector(".more")?.click();
    const btnAguardar = await esperarElemento("//nz-list-item[span[text()='Aguardar']]", 50, 5000);
    btnAguardar?.click();
  }

  async function finalizarInterno() {
    await new Promise(resolve => setTimeout(resolve, 350)); 
    document.querySelector(".more")?.click();
    const finalizar = await esperarElemento("//nz-list-item[span[text()='Finalizar']]", 50, 5000);
    finalizar?.click();
  }

  async function esperarEClicar(xpath, intervalo = 50, timeout = 10000) {
    return new Promise((resolve, reject) => {
      const startTime = Date.now();
      const intervalId = setInterval(() => {
        const elements = document.evaluate(xpath, document, null, XPathResult.ORDERED_NODE_SNAPSHOT_TYPE, null);
        for (let i = 0; i < elements.snapshotLength; i++) {
          const element = elements.snapshotItem(i);
          if (element) { clearInterval(intervalId); element.click(); console.log(`Clicado: ${xpath}`); resolve(); return; }
        }
        if (Date.now() - startTime > timeout) { clearInterval(intervalId); reject(new Error(`Timeout: ${xpath}`)); }
      }, intervalo);
    });
  }

  async function esperarElemento(xpath, intervalo = 50, timeout = 10000) {
    return new Promise((resolve, reject) => {
      const startTime = Date.now();
      const intervalId = setInterval(() => {
        const element = document.evaluate(xpath, document, null, XPathResult.FIRST_ORDERED_NODE_TYPE, null).singleNodeValue;
        if (element) { clearInterval(intervalId); resolve(element); }
        else if (Date.now() - startTime > timeout) { clearInterval(intervalId); reject(new Error(`Timeout: ${xpath}`)); }
      }, intervalo);
    });
  }

  async function clicarComTentativas(xpathParaClicar, xpathParaVerificar, maxTentativas = 60, intervalo = 150) {
    for (let i = 0; i < maxTentativas; i++) {
      const elementoParaClicar = document.evaluate(xpathParaClicar, document, null, XPathResult.FIRST_ORDERED_NODE_TYPE, null).singleNodeValue;
      if (elementoParaClicar) {
        elementoParaClicar.click();
        await new Promise(resolve => setTimeout(resolve, 100));
        const elementoVerificacao = document.evaluate(xpathParaVerificar, document, null, XPathResult.FIRST_ORDERED_NODE_TYPE, null).singleNodeValue;
        if (elementoVerificacao) return;
      }
      await new Promise(resolve => setTimeout(resolve, intervalo));
    }
    throw new Error("Falha ao clicar no elemento.");
  }

  async function esperarElementoHabilitado(xpath, intervalo = 200, timeout = 10000) {
    const startTime = Date.now();
    while (Date.now() - startTime < timeout) {
      const element = document.evaluate(xpath, document, null, XPathResult.FIRST_ORDERED_NODE_TYPE, null).singleNodeValue;
      if (element && !element.classList.contains("ant-select-disabled")) return element;
      await new Promise(resolve => setTimeout(resolve, intervalo));
    }
    throw new Error(`Timeout habilitado: ${xpath}`);
  }

  async function esperarElementoClicavel(xpath, intervalo = 50, timeout = 10000) {
    return await esperarElemento(xpath, intervalo, timeout);
  }
})();
